{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "train.py – simple (debug)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/train.py",
            "python": "${workspaceFolder}/.venv/bin/python",
            "args": ["--mode", "simple"],
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "train.py – advanced (debug)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/train.py",
            "python": "${workspaceFolder}/.venv/bin/python",
            "args": ["--mode", "advanced"],
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "train.py – custom args (debug)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/train.py",
            "python": "${workspaceFolder}/.venv/bin/python",
            "args": ["--mode", "simple", "--max_iters", "200", "--eval_interval", "50"],
            "console": "integratedTerminal",
            "justMyCode": false
        }
    ]
}
